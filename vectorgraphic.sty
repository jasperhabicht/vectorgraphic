\bool_new:N \l__vectorgraphic_node_vbox_bool
\coffin_new:N \l_vectorgraphic_node_coffin

\dim_new:N \l_vectorgraphic_node_width_dim
\dim_new:N \l_vectorgraphic_node_height_dim
\clist_new:N \l_vectorgraphic_node_anchor_clist

\cs_generate_variant:Nn \draw_coffin_use:Nnnn { NeeV }

\keys_define:nn { vectorgraphic / node } {
    at                      .code:n         = {
        \vectorgraphic_parse_coordinate:Nn \l_vectorgraphic_last_coordinate_fp {#1}
    } ,
    anchor                  .clist_set:N    = \l_vectorgraphic_node_anchor_clist ,
    anchor                  .initial:n      = { hc , vc } ,
    width                   .code:n         = {
        \bool_set_true:N \l__vectorgraphic_node_vbox_bool
        \dim_set:Nn \l_vectorgraphic_node_width_dim {#1}
    } ,
    width                   .initial:n      = { 0pt } ,
    height                  .dim_set:N      = \l_vectorgraphic_node_height_dim ,
    height                  .initial:n      = { 0pt } ,
}

\cs_new_protected:cpn { __vectorgraphic_process_path_ n :w } node #1#2 \q_stop {
    \tl_if_head_eq_meaning:nNTF {#1} [ {
        \__vectorgraphic_process_node_options:w #1#2 \q_stop
    } {
        \vectorgraphic_process_node:nn { } {#1}
        \tl_trim_spaces_apply:nN {#2} \__vectorgraphic_continue_path:n
    }
}

\cs_new_protected:Npn \__vectorgraphic_process_node_options:w [ #1 ] #2#3 \q_stop {
    \vectorgraphic_process_node:nn {#1} {#2}
    \tl_trim_spaces_apply:nN {#3} \__vectorgraphic_continue_path:n
}

\cs_new_protected:Npn \vectorgraphic_process_node:nn #1#2 {
    \group_begin:
        \keys_set:nn { vectorgraphic / node } {#1}
        \bool_if:NTF \l__vectorgraphic_node_vbox_bool {
            \vcoffin_set:Nnn \l_vectorgraphic_node_coffin {
                \l_vectorgraphic_node_width_dim
            } {
                \normalfont #2
            }
        } {
            \hcoffin_set:Nn \l_vectorgraphic_node_coffin{
                \normalfont #2
            }
        }
        \draw_coffin_use:NeeV \l_vectorgraphic_node_coffin {
            \clist_item:Nn \l_vectorgraphic_node_anchor_clist { 1 }
        } {
            \clist_item:Nn \l_vectorgraphic_node_anchor_clist { 2 }
        } \l_vectorgraphic_last_coordinate_fp
    \group_end:
}

