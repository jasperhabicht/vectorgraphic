\ProvidesExplPackage {vectorgraphic} {2026-05-14} {0.0.1}
  {An experimental package for drawing vector graphics with the l3draw package and a TikZ-like syntax.}

\msg_new:nnn { vectorgraphic } { old-kernel } {
  LaTeX ~ kernel ~ too ~ old. \iow_newline:
  The ~ vectorgraphic ~ package ~ does ~ not ~ support ~ this ~ LaTeX ~ version. \iow_newline:
  Please ~ update ~ to ~ a ~ newer ~ version.
}

\cs_if_exist:NF \ProcessKeyOptions {
  \msg_critical:nn { vectorgraphic } { old-kernel }
}

% ===

\ProcessKeyOptions [ ]

\RequirePackage { l3draw }

% already working:
% ( > (...) = coordinate
% ! > close path
% - > 
    % -- > lineto:n
% . >
    % .. >
        % .. > curveto:nm
        % & (...) .. > curveto:nnn

% to do:
% [ > [...] = keys
% § > node [...] {}

% + > relative coordinates
% | > orthogonal coordinates

% rectangle, circle, ellipse, arc commands

\clist_new:N \l_vectorgraphic_path_use_clist
\str_new:N \l_vectorgraphic_path_stroke_color_str
\str_new:N \l_vectorgraphic_path_fill_color_str
\fp_new:N \l_vectorgraphic_path_stroke_opacity_fp
\fp_new:N \l_vectorgraphic_path_fill_opacity_fp
\dim_new:N \l_vectorgraphic_path_linewidth_dim

\str_new:N \l_vectorgraphic_path_cap_str
\str_new:N \l_vectorgraphic_path_join_str
\fp_new:N \l_vectorgraphic_path_miterlimit_fp
\clist_new:N \l_vectorgraphic_path_corner_arc_clist

\tl_new:N \l_vectorgraphic_last_coordinate_tl
\tl_new:N \l__vectorgraphic_coordinate_a_tl
\tl_new:N \l__vectorgraphic_coordinate_b_tl

\cs_generate_variant:Nn \color_select:n { V }
\cs_generate_variant:Nn \opacity_select:n { V }
\cs_generate_variant:Nn \draw_set_linewidth:n { V }
\cs_generate_variant:Nn \draw_set_miterlimit:n { V }
\cs_generate_variant:Nn \draw_path_corner_arc:nn { ee }
\cs_generate_variant:Nn \draw_path_use_clear:n { e }

\keys_define:nn { vectorgraphic / env } {
    baseline                .code:n         = { \draw_set_baseline:n {#1} } ,
}

\keys_define:nn { vectorgraphic / path } {
    stroke                  .code:n         = {
        \clist_put_right:Nn \l_vectorgraphic_path_use_clist { stroke }
    } ,
    fill                    .code:n         = {
        \clist_put_right:Nn \l_vectorgraphic_path_use_clist { fill }
    } ,
    clip                    .code:n         = {
        \clist_put_right:Nn \l_vectorgraphic_path_use_clist { clip }
    } ,
    stroke ~ color          .str_set:N      = \l_vectorgraphic_path_stroke_color_str ,
    stroke ~ color          .initial:n      = { . } ,
    fill ~ color            .str_set:N      = \l_vectorgraphic_path_fill_color_str ,
    fill ~ color            .initial:n      = { . } ,
    stroke ~ opacity        .fp_set:N       = \l_vectorgraphic_path_stroke_opacity_fp ,
    stroke ~ opacity        .initial:n      = { 1 } ,
    fill ~ opacity          .fp_set:N       = \l_vectorgraphic_path_fill_opacity_fp ,
    fill ~ opacity          .initial:n      = { 1 } ,
    line ~ width            .dim_set:N      = \l_vectorgraphic_path_linewidth_dim ,
    line ~ width            .initial:n      = { \l_draw_default_linewidth_dim } ,
    line ~ cap              .choice: ,
    line ~ cap / butt       .code:n         = {
        \str_set:Nn \l_vectorgraphic_path_cap_str { butt }
    } ,
    line ~ cap / round      .code:n         = {
        \str_set:Nn \l_vectorgraphic_path_cap_str { round }
    } ,
    line ~ cap / rectangle  .code:n         = {
        \str_set:Nn \l_vectorgraphic_path_cap_str { rectangle }
    } ,
    line ~ cap              .initial:n      = { butt } ,
    line ~ join             .choice: ,
    line ~ join / miter     .code:n         = {
        \str_set:Nn \l_vectorgraphic_path_join_str { miter }
    } ,
    line ~ join / round     .code:n         = {
        \str_set:Nn \l_vectorgraphic_path_join_str { round }
    } ,
    line ~ join / bevel     .code:n         = {
        \str_set:Nn \l_vectorgraphic_path_join_str { bevel }
    } ,
    line ~ join             .initial:n      = { miter } ,
    miter ~ limit           .fp_set:N       = \l_vectorgraphic_path_miterlimit_fp ,
    miter ~ limit           .initial:n      = { 10 } ,
    corner ~ arc            .clist_set:N    = \l_vectorgraphic_path_corner_arc_clist ,
    corner ~ arc            .initial:n      = { 0pt } ,
}

\cs_new:Npn \__vectorgraphic_fp_tuple_use_i:w ( #1 , #2 ) {#1}
\cs_new:Npn \vectorgraphic_fp_tuple_use_i:n #1 {
    \fp_to_dim:n {
        \exp_last_unbraced:Ne
            \__vectorgraphic_fp_tuple_use_i:w { \fp_eval:n {#1} }
    }
}
\cs_generate_variant:Nn \vectorgraphic_fp_tuple_use_i:n { V }

\cs_new:Npn \__vectorgraphic_fp_tuple_use_ii:w ( #1 , #2 ) {#2}
\cs_new:Npn \vectorgraphic_fp_tuple_use_ii:n #1 {
    \fp_to_dim:n {
        \exp_last_unbraced:Ne
            \__vectorgraphic_fp_tuple_use_ii:w { \fp_eval:n {#1} }
    }
}
\cs_generate_variant:Nn \vectorgraphic_fp_tuple_use_ii:n { V }

\cs_new_protected:Npn \vectorgraphic_set_path_options: {
    \color_select:V \l_vectorgraphic_path_stroke_color_str
    \color_select:V \l_vectorgraphic_path_fill_color_str
    \opacity_select:V \l_vectorgraphic_path_stroke_opacity_fp
    \opacity_select:V \l_vectorgraphic_path_fill_opacity_fp
    \draw_set_linewidth:V \l_vectorgraphic_path_linewidth_dim
    \draw_set_miterlimit:V\l_vectorgraphic_path_miterlimit_fp
    \use:c { draw_set_cap_ \l_vectorgraphic_path_cap_str : }
    \use:c { draw_set_join_ \l_vectorgraphic_path_join_str : }
    \int_compare:nNnTF { \clist_count:N \l_vectorgraphic_path_corner_arc_clist } > { 1 } {
        \draw_path_corner_arc:ee {
            \clist_item:Nn \l_vectorgraphic_path_corner_arc_clist { 1 }
        } {
            \clist_item:Nn \l_vectorgraphic_path_corner_arc_clist { 2 }
        }
    } {
        \draw_path_corner_arc:ee {
            \clist_item:Nn \l_vectorgraphic_path_corner_arc_clist { 1 }
        } {
            \clist_item:Nn \l_vectorgraphic_path_corner_arc_clist { 1 }
        }
    }
}

\cs_new_protected:Npn \vectorgraphic_parse_coordinate:Nn #1#2 {
    \tl_if_in:nnTF {#2} { : } {
        \tl_set:Nn #1 {
            \vectorgraphic_parse_coordinate_polar:w #2 \q_stop
        }
    } {
        \tl_set:Nn #1 {#2}
    }
}
\cs_new_protected:Npn \vectorgraphic_parse_coordinate_polar:w #1 : #2 \q_stop {
    \draw_point_polar:nn {#2} {#1}
}

\cs_new_protected:Npn \vectorgraphic_path:w #1 ; {
    \tl_set:Nn \l__vectorgraphic_coordinate_a_tl { 0 , 0 }
    \tl_set:Nn \l__vectorgraphic_coordinate_b_tl { 0 , 0 }
    \tl_set:Nn \l_vectorgraphic_last_coordinate_tl { 0 , 0 }
    \vectorgraphic_set_path_options:
    \tl_trim_spaces_apply:nN {#1} \__vectorgraphic_process_path:n
    \draw_path_use_clear:e { \clist_use:N \l_vectorgraphic_path_use_clist }
}

\cs_new_protected:Npn \__vectorgraphic_process_path:n #1 {
    \tl_set_eq:NN \l_vectorgraphic_last_coordinate_tl \l_vectorgraphic_coordinate_a_tl
    \cs_if_exist_use:cT {
        __vectorgraphic_process_path_ \tl_head:n {#1} :w 
    } {
        #1 \q_stop
    }
}

\cs_new_protected:Npn \__vectorgraphic_continue_path:n #1 {
    \tl_if_blank:nF {#1} {
        \__vectorgraphic_process_path:n {#1}
    }
}

\cs_new_protected:cpn { __vectorgraphic_process_path_ [ :w } [ #1 ] #2 \q_stop {
    \keys_set:nn { vectorgraphic / path } {#1}
    \vectorgraphic_set_path_options:
    \tl_trim_spaces_apply:nN {#2} \__vectorgraphic_continue_path:n
}

\cs_new_protected:cpn { __vectorgraphic_process_path_ ( :w } ( #1 ) #2 \q_stop {
    \vectorgraphic_parse_coordinate:Nn \l__vectorgraphic_coordinate_a_tl {#1}
    \draw_path_moveto:n {
        \l__vectorgraphic_coordinate_a_tl
    }
    \tl_trim_spaces_apply:nN {#2} \__vectorgraphic_continue_path:n
}

\cs_new_protected:cpn { __vectorgraphic_process_path_ - :w } -- #1 ( #2 ) #3 \q_stop {
    % what do we do with #1?
    \vectorgraphic_parse_coordinate:Nn \l__vectorgraphic_coordinate_a_tl {#2}
    \draw_path_lineto:n {
        \l__vectorgraphic_coordinate_a_tl
    }
    \tl_trim_spaces_apply:nN {#3} \__vectorgraphic_continue_path:n
}

\cs_new:Npn \__vectorgraphic_process_curve_path:n #1 {
    \cs_if_exist_use:cT {
        __vectorgraphic_process_path_curve_ \tl_head:n {#1} :w 
    } {
        #1 \q_stop
    }
}

\cs_new_protected:cpn { __vectorgraphic_process_path_ . :w } .. #1 ( #2 ) #3 \q_stop {
    % what do we do with #1?
    \vectorgraphic_parse_coordinate:Nn \l__vectorgraphic_coordinate_a_tl {#2}
     \tl_trim_spaces_apply:nN {#3} \__vectorgraphic_process_curve_path:n
}

\cs_new_protected:cpn { __vectorgraphic_process_path_curve_ . :w } .. #1 ( #2 ) #3 \q_stop {
    % what do we do with #1?
    \tl_set_eq:NN \l_vectorgraphic_last_coordinate_tl \l__vectorgraphic_coordinate_a_tl
    \vectorgraphic_parse_coordinate:Nn \l__vectorgraphic_coordinate_a_tl {#2}
    \draw_path_curveto:nn {
        \l_vectorgraphic_last_coordinate_tl
    } {
        \l__vectorgraphic_coordinate_a_tl
    }
    \tl_trim_spaces_apply:nN {#3} \__vectorgraphic_continue_path:n
}

\cs_new_protected:cpn { __vectorgraphic_process_path_curve_ & :w } & #1 ( #2 ) #3 .. #4 ( #5 ) #6 \q_stop {
    % what do we do with #1, #3, #4?
    \tl_set_eq:NN \l_vectorgraphic_last_coordinate_tl \l__vectorgraphic_coordinate_a_tl
    \vectorgraphic_parse_coordinate:Nn \l__vectorgraphic_coordinate_a_tl {#2}
    \vectorgraphic_parse_coordinate:Nn \l__vectorgraphic_coordinate_b_tl {#5}
    \draw_path_curveto:nnn {
        \l_vectorgraphic_last_coordinate_tl
    } {
        \l__vectorgraphic_coordinate_a_tl
    } {
        \l__vectorgraphic_coordinate_b_tl
    }
    \tl_trim_spaces_apply:nN {#6} \__vectorgraphic_continue_path:n
}

\cs_new_protected:cpn { __vectorgraphic_process_path_ ! :w } ! #1 \q_stop {
    \draw_path_close:
    \tl_trim_spaces_apply:nN {#1} \__vectorgraphic_continue_path:n
}

% ===

\NewDocumentEnvironment { vectorgraphic } { O{} } {
    \cs_set_eq:NN \path \vectorgraphic_path:w
    \keys_set:nn { vectorgraphic / env } {#1}
    \draw_begin:
} {
    \draw_end:
}

