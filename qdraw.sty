\cs_new_protected:Npn \qdraw_set_path_options: {
    \color_stroke:V \l_qdraw_path_stroke_color_str
    \color_fill:V \l_qdraw_path_fill_color_str
    \opacity_stroke:V \l_qdraw_path_stroke_opacity_fp
    \opacity_fill:V \l_qdraw_path_fill_opacity_fp
    \draw_set_linewidth:V \l_qdraw_path_linewidth_dim
    \draw_set_miterlimit:V\l_qdraw_path_miterlimit_fp
    \use:c { draw_set_cap_ \l_qdraw_path_cap_str : }
    \use:c { draw_set_join_ \l_qdraw_path_join_str : }
    \int_compare:nNnTF { \clist_count:N \l_qdraw_path_corner_arc_clist } > { 1 } {
        \draw_path_corner_arc:ee {
            \clist_item:Nn \l_qdraw_path_corner_arc_clist { 1 }
        } {
            \clist_item:Nn \l_qdraw_path_corner_arc_clist { 2 }
        }
    } {
        \draw_path_corner_arc:ee {
            \clist_item:Nn \l_qdraw_path_corner_arc_clist { 1 }
        } {
            \clist_item:Nn \l_qdraw_path_corner_arc_clist { 1 }
        }
    }
    \use:c { draw_set_ \l_qdraw_path_fill_rule_str _rule: }
    \draw_set_dash_pattern:VV \l_qdraw_path_dash_pattern_clist
        \l_qdraw_path_dash_phase_dim
    \draw_transform_shift:V \l_qdraw_path_shift_fp
    \draw_transform_rotate:V \l_qdraw_path_rotate_fp
    \int_compare:nNnTF { \clist_count:N \l_qdraw_path_scale_clist } > { 1 } {
        \draw_transform_xscale:e {
            \clist_item:Nn \l_qdraw_path_scale_clist { 1 }
        }
        \draw_transform_yscale:e {
            \clist_item:Nn \l_qdraw_path_scale_clist { 2 }
        }
    } {
        \draw_transform_scale:e {
            \clist_item:Nn \l_qdraw_path_scale_clist { 1 }
        }
    }
    \int_compare:nNnTF { \clist_count:N \l_qdraw_path_slant_clist } > { 1 } {
        \draw_transform_xslant:e {
            \clist_item:Nn \l_qdraw_path_slant_clist { 1 }
        }
        \draw_transform_yslant:e {
            \clist_item:Nn \l_qdraw_path_slant_clist { 2 }
        }
    } {
        \draw_transform_xslant:e {
            \clist_item:Nn \l_qdraw_path_slant_clist { 1 }
        }
        \draw_transform_yslant:e {
            \clist_item:Nn \l_qdraw_path_slant_clist { 1 }
        }
    }
}

% ===

\scan_new:N \s__qdraw_stop

\fp_new:N \l_qdraw_point_at_fp
\tl_new:N \l_qdraw_point_name_tl

\keys_define:nn { qdraw / path / point } {
    at                      .fp_set:N       = \l_qdraw_point_at_fp ,
    name                    .tl_set:N       = \l_qdraw_point_name_tl ,
}

\cs_new_protected:cpn { __qdraw_process_path_ p :w } point #1 [ #2 ] #3 \s__qdraw_stop {
    \fp_set_eq:NN \l_qdraw_point_at_fp \l_qdraw_path_last_point_fp
    \keys_set:nn { qdraw / path / point } {#2}
    \prop_gput:cVV { g__qdraw_points_ \int_use:N \g_qdraw_id_int _prop }
        \l_qdraw_point_name_tl
        \l_qdraw_point_at_fp
    \tl_trim_spaces_apply:nN {#3} \__qdraw_continue_path:n
}

\cs_new_protected:Npn \qdraw_parse_point:Nn #1#2 {
    \prop_if_in:cnTF {
        g__qdraw_points_ \int_use:N \g_qdraw_id_int _prop
    } {#2} {
        \exp_args:NNe
        \fp_set:Nn #1 {
            \prop_item:cn {
                g__qdraw_points_ \int_use:N \g_qdraw_id_int _prop
            } {#2}
        }
    } {
        \tl_if_in:nVTF {#2} \c_colon_str {
            \fp_set:Nn #1 {
                \__qdraw_parse_point_polar:w #2 \s__qdraw_stop
            }
        } {
            \fp_set:Nn #1 {#2}
        }
    }
}

\exp_last_unbraced:NNNNo
\cs_new:Npn \__qdraw_parse_point_polar:w #1 \c_colon_str #2 \s__qdraw_stop {
    \int_compare:nNnTF { \clist_count:n {#2} } > { 1 } {
        \draw_point_polar:nnn {
            \clist_item:nn {#2} { 1 }
        } {
            \clist_item:nn {#2} { 2 }
        } {#1}
    } {
        \draw_point_polar:nn {#2} {#1}
    }
}

% ===

\cs_new:Npn \qdraw_calculate_slope:nn #1#2 {
    \fp_eval:n {
        atand (
            \qdraw_fp_tuple_use_ii:n {#2} -
            \qdraw_fp_tuple_use_ii:n {#1}
        ,
            \qdraw_fp_tuple_use_i:n {#2} -
            \qdraw_fp_tuple_use_i:n {#1}
        ) - 90
    }
}
\cs_generate_variant:Nn \qdraw_calculate_slope:nn { nV , Vn , VV }

% ===

\cs_new_protected:Npn \qdraw_path:w #1 ; {
    \draw_scope_begin:
        \fp_set:Nn \l__qdraw_point_a_fp { ( 0pt , 0pt ) }
        \fp_set:Nn \l__qdraw_point_b_fp { ( 0pt , 0pt ) }
        \fp_set:Nn \l_qdraw_path_first_point_fp { ( 0pt , 0pt ) }
        \fp_set:Nn \l_qdraw_path_last_point_fp { ( 0pt , 0pt ) }
        \fp_set:Nn \l_qdraw_path_first_slope_fp { nan }
        \fp_set:Nn \l_qdraw_path_last_slope_fp { nan }
        \tl_use:N \l_qdraw_path_preactions_tl
        \tl_trim_spaces_apply:nN {#1} \__qdraw_process_path:e
        \clist_remove_duplicates:N \l_qdraw_path_use_clist
        \draw_path_use_clear:e { \clist_use:N \l_qdraw_path_use_clist }
        \tl_use:N \l_qdraw_path_postactions_tl
    \draw_scope_end:
    \bool_if:NT \g__qdraw_path_use_clip_bool {
        \bool_set_true:N \l__qdraw_path_clip_bool
        \tl_trim_spaces_apply:nN {#1} \__qdraw_process_path:e
        \draw_path_use_clear:n { clip }
        \bool_set_false:N \l__qdraw_path_clip_bool
        \bool_gset_false:N \g__qdraw_path_use_clip_bool
    }
}

\cs_new_protected:Npn \__qdraw_process_path:n #1 {
    \cs_if_exist_use:cT {
        __qdraw_process_path_ \tl_head:n {#1} :w
    } {
        #1 \s__qdraw_stop
    }
}
\cs_generate_variant:Nn \__qdraw_process_path:n { e }

\cs_new_protected:Npn \__qdraw_continue_path:n #1 {
    \tl_if_blank:nF {#1} {
        \__qdraw_process_path:n {#1}
    }
}

\cs_new_protected:cpn { __qdraw_process_path_ [ :w } [ #1 ] #2 \s__qdraw_stop {
    \bool_if:NF \l__qdraw_path_clip_bool {
        \keys_set:nn { qdraw / path } {#1}
        \qdraw_set_path_options:
    }
    \tl_trim_spaces_apply:nN {#2} \__qdraw_continue_path:n
}

\cs_new_protected:cpn { __qdraw_process_path_ ( :w } ( #1 ) #2 \s__qdraw_stop {
    \qdraw_parse_point:Nn \l__qdraw_point_a_fp {#1}
    \draw_path_moveto:n {
        \l__qdraw_point_a_fp
    }
    \fp_set_eq:NN \l_qdraw_path_first_point_fp \l__qdraw_point_a_fp
    \fp_set_eq:NN \l_qdraw_path_last_point_fp \l__qdraw_point_a_fp
    \tl_trim_spaces_apply:nN {#2} \__qdraw_continue_path:n
}

% ===

\cs_new:Npn \__qdraw_process_line_path:n #1 {
    \cs_if_exist_use:cT {
        __qdraw_process_path_line_ \tl_head:n {#1} :w
    } {
        #1 \s__qdraw_stop
    }
}

\cs_new_protected:cpn { __qdraw_process_path_ - :w } - #1 \s__qdraw_stop {
    \tl_trim_spaces_apply:nN {#1} \__qdraw_process_line_path:n
}

\cs_new_protected:cpn { __qdraw_process_path_line_ - :w } - #1 ( #2 ) #3 \s__qdraw_stop {
    % what do we do with #1?
    \qdraw_parse_point:Nn \l__qdraw_point_a_fp {#2}
    \draw_path_lineto:n {
        \l__qdraw_point_a_fp
    }
    \fp_if_nan:nT { \l_qdraw_path_first_slope_fp } {
        \fp_set:Nn \l_qdraw_path_first_slope_fp { 
            \qdraw_calculate_slope:VV \l__qdraw_point_a_fp \l_qdraw_path_last_point_fp
        }
    }
    \fp_set:Nn \l_qdraw_path_last_slope_fp { 
        \qdraw_calculate_slope:VV \l_qdraw_path_last_point_fp \l__qdraw_point_a_fp
    }
    \fp_set_eq:NN \l_qdraw_path_last_point_fp \l__qdraw_point_a_fp
    \tl_trim_spaces_apply:nN {#3} \__qdraw_continue_path:n
}

\cs_new_protected:cpn { __qdraw_process_path_line_ | :w } | #1 ( #2 ) #3 \s__qdraw_stop {
    % what do we do with #1?
    \qdraw_parse_point:Nn \l__qdraw_point_a_fp {#2}
    \qdraw_parse_point:Nn \l__qdraw_point_b_fp {
        (
            \qdraw_fp_tuple_use_i:V \l__qdraw_point_a_fp
        ,
            \qdraw_fp_tuple_use_ii:V \l_qdraw_path_last_point_fp
        )
    }
    \draw_path_lineto:n {
        \l__qdraw_point_b_fp 
    }
    \draw_path_lineto:n {
        \l__qdraw_point_a_fp
    }
    \fp_if_nan:nT { \l_qdraw_path_first_slope_fp } {
        \fp_set:Nn \l_qdraw_path_first_slope_fp { 
            \qdraw_calculate_slope:VV \l__qdraw_point_b_fp \l_qdraw_path_last_point_fp
        }
    }
    \fp_set:Nn \l_qdraw_path_last_slope_fp { 
        \qdraw_calculate_slope:VV \l__qdraw_point_b_fp \l__qdraw_point_a_fp
    }
    \fp_set_eq:NN \l_qdraw_path_last_point_fp \l__qdraw_point_a_fp
    \tl_trim_spaces_apply:nN {#3} \__qdraw_continue_path:n
}


\cs_new_protected:cpn { __qdraw_process_path_ | :w } |- #1 ( #2 ) #3 \s__qdraw_stop {
    % what do we do with #1?
    \qdraw_parse_point:Nn \l__qdraw_point_a_fp {#2}
    \qdraw_parse_point:Nn \l__qdraw_point_b_fp {
        (
            \qdraw_fp_tuple_use_i:V \l_qdraw_path_last_point_fp
        ,
            \qdraw_fp_tuple_use_ii:V \l__qdraw_point_a_fp
        )
    }
    \draw_path_lineto:n {
        \l__qdraw_point_b_fp 
    }
    \draw_path_lineto:n {
        \l__qdraw_point_a_fp
    }
    \fp_if_nan:nT { \l_qdraw_path_first_slope_fp } {
        \fp_set:Nn \l_qdraw_path_first_slope_fp { 
            \qdraw_calculate_slope:VV \l__qdraw_point_b_fp \l_qdraw_path_last_point_fp
        }
    }
    \fp_set:Nn \l_qdraw_path_last_slope_fp { 
        \qdraw_calculate_slope:VV \l__qdraw_point_b_fp \l__qdraw_point_a_fp
    }
