    stroke                  .code:n         = {
        \clist_put_right:Nn \l_qdraw_path_use_clist { stroke }
    } ,
    fill                    .code:n         = {
        \clist_put_right:Nn \l_qdraw_path_use_clist { fill }
    } ,
    clip                    .bool_gset:N    = \g__qdraw_path_use_clip_bool ,
    clip                    .default:n      = { true } ,
    clip                    .initial:n      = { false } ,
    stroke ~ color          .str_set:N      = \l_qdraw_path_stroke_color_str ,
    stroke ~ color          .initial:n      = { . } ,
    fill ~ color            .str_set:N      = \l_qdraw_path_fill_color_str ,
    fill ~ color            .initial:n      = { . } ,
    stroke ~ opacity        .fp_set:N       = \l_qdraw_path_stroke_opacity_fp ,
    stroke ~ opacity        .initial:n      = { 1 } ,
    fill ~ opacity          .fp_set:N       = \l_qdraw_path_fill_opacity_fp ,
    fill ~ opacity          .initial:n      = { 1 } ,
    line ~ width            .dim_set:N      = \l_qdraw_path_linewidth_dim ,
    line ~ width            .initial:V      = \l_draw_default_linewidth_dim ,
    line ~ cap              .choice: ,
    line ~ cap / butt       .code:n         = {
        \str_set:Nn \l_qdraw_path_cap_str { butt }
    } ,
    line ~ cap / round      .code:n         = {
        \str_set:Nn \l_qdraw_path_cap_str { round }
    } ,
    line ~ cap / rectangle  .code:n         = {
        \str_set:Nn \l_qdraw_path_cap_str { rectangle }
    } ,
    line ~ cap              .initial:n      = { butt } ,
    line ~ join             .choice: ,
    line ~ join / miter     .code:n         = {
        \str_set:Nn \l_qdraw_path_join_str { miter }
    } ,
    line ~ join / round     .code:n         = {
        \str_set:Nn \l_qdraw_path_join_str { round }
    } ,
    line ~ join / bevel     .code:n         = {
