\cs_new_protected:Npn \__qdraw_style_set:nn #1#2 {
    \clist_if_exist:cF { l__qdraw_style_ #1 _value_clist } {
        \clist_new:c { l__qdraw_style_ #1 _value_clist }
    }
    \clist_put_right:cn { l__qdraw_style_ #1 _value_clist } {#2}
    \keys_define:ne { qdraw / path } {
        #1                  .meta:n         = {
            \clist_use:c { l__qdraw_style_ #1 _value_clist }
        }
    }
}

\cs_new_protected:Npn \__qdraw_style_put_right:nn #1#2 {
    \clist_if_exist:cTF { l__qdraw_style_ #1 _value_clist } {
        \clist_put_right:cn { l__qdraw_style_ #1 _value_clist } {#2}
        \keys_define:ne { qdraw / path } {
            #1              .meta:n         = {
                \clist_use:c { l__qdraw_style_ #1 _value_clist }
            }
        }
    } {
        \msg_error:nnn { qdraw } { style-undefined } {#1}
    }
}

\keys_define:nn { qdraw / path } {
    style ~ set             .code:n         = {
        \keyval_parse:NNn \use:n \__qdraw_style_set:nn {#1}
    } ,
    style ~ add             .code:n         = {
        \keyval_parse:NNn \use:n \__qdraw_style_put_right:nn {#1}
    } ,
}

