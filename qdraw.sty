\NewDocumentEnvironment { qdraw } { O{} } {
    \mode_leave_vertical:
    \nullfont
    % ensure that relevant characters are not active
    \int_gincr:N \g_qdraw_id_int
    \prop_if_exist:cF {
        g__qdraw_points_ \int_use:N \g_qdraw_id_int _prop
    } {
        \prop_new_linked:c {
            g__qdraw_points_ \int_use:N \g_qdraw_id_int _prop
        }
    }
    \cs_set_eq:NN \path \qdraw_path:w
    \cs_set:Npn \stroke { \path [ stroke ] }
    \cs_set:Npn \fill { \path [ fill ] }
    \cs_set:Npn \clip { \path [ clip ] }
    \cs_set:Npn \node { \path ( 0pt , 0pt ) node }
    \cs_set:Npn \point { \path ( 0pt , 0pt ) point }
    \cs_set:Npn \map { \path ( 0pt , 0pt ) map }
    \NewDocumentEnvironment { scope } { O{} } {
        \draw_scope_begin:
            \clist_clear:N \l__qdraw_keys_unprocessed_clist
            \keys_set_known:nnN { qdraw / scope } {##1}
                \l__qdraw_keys_unprocessed_clist
            \keys_set:nV { qdraw / path } \l__qdraw_keys_unprocessed_clist
            \str_if_empty:NF \l_qdraw_scope_layer_str {
                \draw_layer_begin:V \l_qdraw_scope_layer_str
            }
    } {
            \str_if_empty:NF \l_qdraw_scope_layer_str {
                \draw_layer_end:
            }
        \draw_scope_end:
    }
    \clist_clear:N \l__qdraw_keys_unprocessed_clist
    \fp_set:Nn \l_draw_instance_baseline_fp { nan }
    \keys_set_known:nnN { qdraw / instance } {#1}
        \l__qdraw_keys_unprocessed_clist
    \keys_set:nV { qdraw / path } \l__qdraw_keys_unprocessed_clist
    \draw_begin:
        \fp_if_nan:nF { \l_draw_instance_baseline_fp } {
            \draw_set_baseline:n { \l_draw_instance_baseline_fp }
        }
        \bool_if:NT \l_qdraw_instance_overlay_bool {
            \bool_set_false:N \l_draw_bb_update_bool
        }
} {
